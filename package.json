{
  "name": "@adobe/aem-boilerplate",
  "private": true,
  "version": "1.3.0",
  "description": "Starter project for Adobe Helix",
  "scripts": {
    "lint": "npm run lint:run && npm run lint:fix",
    "lint:run": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "merge-json-cli": "1.0.4",
    "oxfmt": "^0.24.0",
    "oxlint": "^0.16.2",
    "stylelint": "16.17.0",
    "stylelint-config-standard": "36.0.1"
  },
  "lint-staged": {
    "*": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint --fix"
    ]
  },
  "pnpm": {
    "overrides": {
      "@octokit/request-error@>=1.0.0 <5.1.1": ">=5.1.1",
      "@octokit/request@>=1.0.0 <8.4.1": ">=8.4.1",
      "@octokit/plugin-paginate-rest@>=1.0.0 <9.2.2": ">=9.2.2",
      "brace-expansion@>=1.0.0 <=1.1.11": ">=1.1.12",
      "brace-expansion@>=2.0.0 <=2.0.1": ">=2.0.2",
      "vite-plugin-static-copy@>=0.4.3 <=2.3.1": ">=2.3.2",
      "vite@>=6.0.0 <=6.3.5": ">=6.3.6",
      "axios@>=1.0.0 <1.12.0": ">=1.12.0",
      "vite@>=6.0.0 <=6.4.0": ">=6.4.1",
      "tar-fs@>=2.0.0 <2.1.4": ">=2.1.4",
      "tar-fs@>=2.0.0 <2.1.3": ">=2.1.3",
      "tar-fs@>=2.0.0 <2.1.2": ">=2.1.2",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0"
    }
  }
}

